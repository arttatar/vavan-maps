function getRankTitle(idx) {
  if (idx === 0) return 'Board Boss';
  if (idx === 1) return 'Heat Runner';
  if (idx === 2) return 'Strike Hunter';
  return 'Chasing The Leader';
}

function getProgressLabel(row, leaderScore) {
  if (!leaderScore || row.total === leaderScore) return 'Setting the pace';
  return (leaderScore - row.total) + ' pts behind first place';
}

function buildTeamRows(userRows) {
  var teams = {};
  var usedUsers = {};

  TEAM_GROUPS.forEach(function(team){
    var teamRow = buildEmptyRow(team.name);
    var hit = false;
    userRows.forEach(function(row){
      var matched = team.members.some(function(member){
        return matchMemberName(row.user, member);
      });
      if (!matched) return;
      mergeRowInto(teamRow, row);
      usedUsers[row.user] = true;
      hit = true;
    });
    teams[team.name] = teamRow;
  });

  SOLO_TEAM_MEMBERS.forEach(function(member){
    var found = false;
    userRows.forEach(function(row){
      if (matchMemberName(row.user, member)) {
        teams[row.user] = cloneRow(row, row.user);
        usedUsers[row.user] = true;
        found = true;
      }
    });
    if (!found) teams[member] = buildEmptyRow(member);
  });

  userRows.forEach(function(row){
    if (!usedUsers[row.user]) {
      teams[row.user] = cloneRow(row, row.user);
    }
  });

  return sortAllRows(teams);
}

function buildLoneWolfRows(userRows) {
  var lone = {};
  SOLO_TEAM_MEMBERS.forEach(function(member){
    var found = false;
    userRows.forEach(function(row){
      if (matchMemberName(row.user, member)) {
        lone[row.user] = cloneRow(row, row.user);
        found = true;
      }
    });
    if (!found) lone[member] = buildEmptyRow(member);
  });
  return sortAllRows(lone);
}

function renderActiveBoard(userRows) {
