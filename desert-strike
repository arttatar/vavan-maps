  var leaderScore = rows[0].total || 0;
  host.innerHTML = rows.map(function(row, idx){
    var rowClass = idx === 0 ? 'leader-row top-1' : idx === 1 ? 'leader-row top-2' : idx === 2 ? 'leader-row top-3' : 'leader-row';
    var percent = leaderScore ? Math.max(10, Math.round((row.total / leaderScore) * 100)) : 0;
    var stats = CATEGORY_ORDER.map(function(key){
      var label = POINT_RULES[key].label;
      var count = row.counts[key] || 0;
      var pts = row.points[key] || 0;
      var chipClass = 'stat-chip clickable' + (pts ? ' hot' : '') + (_auditFilterKey === key ? ' active-filter' : '');
      return '<div class="'+chipClass+'" onclick="setAuditFilter(\''+key+'\')">'+
        '<div class="stat-label">'+escapeHtml(label)+'</div>'+
        '<div class="stat-value">'+count+'</div>'+
        '<div class="stat-points">'+pts+' pts</div>'+
      '</div>';
    }).join('');

    return '<div class="'+rowClass+'">'+
      '<div class="rank">#'+(idx + 1)+'</div>'+
      '<div>'+
        '<div class="rep-topline">'+
          '<div class="rep-name">'+escapeHtml(row.user)+'</div>'+
          '<div class="rank-title">'+escapeHtml(getRankTitle(idx))+'</div>'+
        '</div>'+
        '<div class="rep-sub">InterState Oil blitz standings</div>'+
        '<div class="progress-track"><div class="progress-fill" style="width:'+percent+'%;"></div></div>'+
        '<div class="progress-copy">'+escapeHtml(getProgressLabel(row, leaderScore))+'</div>'+
      '</div>'+
      '<div class="total-box">'+
        '<div class="total-label">Total</div>'+
        '<div class="total-value">'+row.total+'</div>'+
      '</div>'+
      '<div class="stat-grid">'+stats+'</div>'+
    '</div>';
  }).join('');
}

function buildSeedRows(users) {
  var rows = {};
  (users || []).forEach(function(user){
    var name = normalizeName(user.full_name);
    if (!name || user.active === false || user.role === 'vavan_super') return;
    rows[name] = buildEmptyRow(name);
  });
  return rows;
}

function inRangeQuery(query, field, range) {
  return query.gte(field, range.startIso).lt(field, range.endIso);
}

function sortRows(rows) {
  return Object.keys(rows).map(function(key){ return rows[key]; })
    .filter(function(row){ return row.total > 0; })
    .sort(function(a, b){
      if (b.total !== a.total) return b.total - a.total;
      if ((b.counts.competitor_invoice||0) !== (a.counts.competitor_invoice||0)) {
        return (b.counts.competitor_invoice||0) - (a.counts.competitor_invoice||0);
      }
      if ((b.counts.credit_app_collected||0) !== (a.counts.credit_app_collected||0)) {
        return (b.counts.credit_app_collected||0) - (a.counts.credit_app_collected||0);
      }
      return a.user.localeCompare(b.user);
    });
}

function sortAllRows(rows) {
  return Object.keys(rows).map(function(key){ return rows[key]; })
    .sort(function(a, b){
      if (b.total !== a.total) return b.total - a.total;
      if ((b.counts.competitor_invoice||0) !== (a.counts.competitor_invoice||0)) {
        return (b.counts.competitor_invoice||0) - (a.counts.competitor_invoice||0);
      }
      if ((b.counts.credit_app_collected||0) !== (a.counts.credit_app_collected||0)) {
        return (b.counts.credit_app_collected||0) - (a.counts.credit_app_collected||0);
      }
      return a.user.localeCompare(b.user);
    });
}

function isMissingRelation(err) {
  var msg = String(err && (err.message || err.details || err.hint) || '');
  return /could not find the table|relation .* does not exist|schema cache/i.test(msg);
}

async function loadBoard() {
  if (!_currentProfile) return;
  var range = makeDateRange();
  if (!range) {
    alert('Please choose a valid start and end date.');
    return;
  }

  var btn = document.getElementById('reload-btn');
  btn.disabled = true;
  btn.textContent = 'Loading...';

  try {
    _auditEvents = [];
    _businessNameMap = {};
    var usersRes = await sb.from('sales_profiles')
      .select('id, full_name, role, active')
      .eq('client_id', _currentProfile.client_id)
      .order('full_name', { ascending:true });
    if (usersRes.error) throw usersRes.error;

    var bizRes = await sb.from('businesses')
      .select('id, business_name')
      .eq('client_id', _currentProfile.client_id);
    if (!bizRes.error) {
      (bizRes.data || []).forEach(function(biz){
        _businessNameMap[String(biz.id)] = biz.business_name || '';
      });
    }

    var rows = buildSeedRows(usersRes.data || []);

    var activityQuery = sb.from('activity')
      .select('type, note, created_by, created_at, business_id')
      .eq('client_id', _currentProfile.client_id);
    activityQuery = inRangeQuery(activityQuery, 'created_at', range);
    var activityRes = await activityQuery;
    if (activityRes.error) throw activityRes.error;

    (activityRes.data || []).forEach(function(item){
      var row = ensureRow(rows, item.created_by);
      if (!row) return;
      var note = normalizeName(item.note);
      if (item.type === 'visited') {
        addScore(row, 'visit', 1);
        pushAuditEvent({ user:item.created_by, key:'visit', detail:note || 'Visited logged', source:'activity', created_at:item.created_at, business_id:item.business_id });
      }
      if (item.type === 'contact' && /^Contact added:/i.test(note)) {
        addScore(row, 'contact_added', 1);
        pushAuditEvent({ user:item.created_by, key:'contact_added', detail:note, source:'activity', created_at:item.created_at, business_id:item.business_id });
      }
      if (CREDIT_LEFT_RX.test(note)) {
        addScore(row, 'credit_app_left', 1);
        pushAuditEvent({ user:item.created_by, key:'credit_app_left', detail:note, source:'activity', created_at:item.created_at, business_id:item.business_id });
      }
      if (CREDIT_COLLECTED_RX.test(note)) {
        addScore(row, 'credit_app_collected', 1);
        pushAuditEvent({ user:item.created_by, key:'credit_app_collected', detail:note, source:'activity', created_at:item.created_at, business_id:item.business_id });
      }
    });

    try {
      var photoQuery = sb.from('business_photos')
        .select('caption, file_name, uploaded_by, created_at, business_id')
        .eq('client_id', _currentProfile.client_id);
      photoQuery = inRangeQuery(photoQuery, 'created_at', range);
      var photoRes = await photoQuery;
      if (photoRes.error) throw photoRes.error;

      (photoRes.data || []).forEach(function(photo){
        var row = ensureRow(rows, photo.uploaded_by);
        if (!row) return;
        var hay = [photo.caption, photo.file_name].filter(Boolean).join(' ');
        if (INVOICE_RX.test(hay)) {
          addScore(row, 'competitor_invoice', 1);
          pushAuditEvent({ user:photo.uploaded_by, key:'competitor_invoice', detail:hay || 'Competitor invoice photo', source:'photo', created_at:photo.created_at, business_id:photo.business_id });
        } else if (EQUIPMENT_RX.test(hay)) {
          addScore(row, 'equipment_photo', 1);
          pushAuditEvent({ user:photo.uploaded_by, key:'equipment_photo', detail:hay || 'Equipment photo', source:'photo', created_at:photo.created_at, business_id:photo.business_id });
        }
      });
    } catch (photoErr) {
      if (!isMissingRelation(photoErr)) throw photoErr;
      console.warn('Photo scoring skipped:', photoErr.message || photoErr);
    }

    var oppQuery = sb.from('business_opportunities')
      .select('*')
      .eq('client_id', _currentProfile.client_id);
    oppQuery = inRangeQuery(oppQuery, 'updated_at', range);
    var oppRes = await oppQuery;
    if (oppRes.error) throw oppRes.error;

    (oppRes.data || []).forEach(function(opp){
      var row = ensureRow(rows, opp.updated_by);
      if (!row) return;

      PRODUCT_LINES.forEach(function(product){
        if (!opp['uses_' + product.key]) return;
        var supplier = normalizeName(opp[product.field + '_supplier']);
        var stage = opp[product.field + '_stage'] || '';
        var notes = opp[product.field + '_notes'] || '';
        if (supplier) {
          addScore(row, 'supplier_captured', 1);
          pushAuditEvent({ user:opp.updated_by, key:'supplier_captured', detail:product.label + ' supplier: ' + supplier, source:'opportunity', created_at:opp.updated_at, business_id:opp.business_id });
        }
        if (stage === 'Credit Application') {
          addScore(row, 'credit_app', 1);
          pushAuditEvent({ user:opp.updated_by, key:'credit_app', detail:product.label + ' moved to Credit Application', source:'opportunity', created_at:opp.updated_at, business_id:opp.business_id });
        }
        if (isMeaningfulText(notes)) {
          addScore(row, 'pain_points', 1);
          pushAuditEvent({ user:opp.updated_by, key:'pain_points', detail:product.label + ' notes captured', source:'opportunity', created_at:opp.updated_at, business_id:opp.business_id });
        }
      });

      if (splitMulti(opp.lube_brands).length) {
        addScore(row, 'brands_captured', 1);
        pushAuditEvent({ user:opp.updated_by, key:'brands_captured', detail:'Lube brands: ' + splitMulti(opp.lube_brands).join(', '), source:'opportunity', created_at:opp.updated_at, business_id:opp.business_id });
      }
    });

    var sorted = sortRows(rows);
    window._lastRowsCache = sorted;
    renderActiveBoard(sorted);
    renderAuditLog();
    document.getElementById('updated-at').textContent = fmtTime(new Date());
  } catch (err) {
    alert(err.message || 'Could not load the leader board.');
  } finally {
    btn.disabled = false;
    btn.textContent = 'Reload';
  }
}

async function boot() {
  var profile = await loadCurrentProfile();
  if (!profile) {
    document.getElementById('app-view').classList.add('hidden');
    document.getElementById('login-view').classList.remove('hidden');
    return;
  }

  _currentProfile = profile;

  if (profile.client_id) {
    var clientRes = await sb.from('clients').select('name').eq('id', profile.client_id).maybeSingle();
    if (!clientRes.error && clientRes.data && clientRes.data.name) _clientName = clientRes.data.name;
  }

  var today = new Date();
  var monthStart = new Date(today.getFullYear(), today.getMonth(), 1);
  document.getElementById('start-date').value = fmtDate(monthStart);
  document.getElementById('end-date').value = fmtDate(today);

  renderRules();
  updateBoardHeadings();
  document.getElementById('client-name').textContent = _clientName;
  document.getElementById('viewer-name').textContent = profile.full_name || 'Unknown';
  document.getElementById('updated-at').textContent = fmtTime(new Date());
  document.getElementById('login-view').classList.add('hidden');
  document.getElementById('app-view').classList.remove('hidden');
  await loadBoard();
}

sb.auth.onAuthStateChange(function(_event, session){
  if (session && session.user) boot();
});

(async function init(){
  try {
    var session = await sb.auth.getSession();
    if (session.data && session.data.session) await boot();
    else document.getElementById('login-view').classList.remove('hidden');
  } catch (err) {
    document.getElementById('login-view').classList.remove('hidden');
    document.getElementById('login-status').textContent = err.message || 'Could not start the page.';
  }
})();
</script>
