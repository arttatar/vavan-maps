function normalizeName(value) {
  return String(value || '').trim();
}

function escapeHtml(value) {
  return String(value || '').replace(/[&<>"']/g, function(ch){
    return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[ch];
  });
}

function fmtTime(date) {
  return new Intl.DateTimeFormat('en-US', {
    month:'short', day:'numeric', hour:'numeric', minute:'2-digit'
  }).format(date);
}

function fmtDate(date) {
  return date.toISOString().slice(0, 10);
}

function isMeaningfulText(value) {
  return normalizeName(value).length >= 15;
}

function splitMulti(value) {
  return String(value || '')
    .split(',')
    .map(function(item){ return item.trim(); })
    .filter(Boolean);
}

function buildEmptyRow(name) {
  var row = { user:name, total:0, points:{}, counts:{} };
  CATEGORY_ORDER.forEach(function(key){
    row.points[key] = 0;
    row.counts[key] = 0;
  });
  return row;
}

function cloneRow(row, nameOverride) {
  var next = buildEmptyRow(nameOverride || row.user);
  CATEGORY_ORDER.forEach(function(key){
    next.points[key] = row.points[key] || 0;
    next.counts[key] = row.counts[key] || 0;
  });
  next.total = row.total || 0;
  return next;
}

function ensureRow(rows, name) {
  var userName = normalizeName(name);
  if (!userName) return null;
  if (!rows[userName]) rows[userName] = buildEmptyRow(userName);
  return rows[userName];
}

function addScore(row, key, count) {
  if (!row || !POINT_RULES[key] || !count) return;
  row.counts[key] += count;
  row.points[key] += count * POINT_RULES[key].points;
  row.total += count * POINT_RULES[key].points;
}

function pushAuditEvent(entry) {
  if (!entry || !entry.key || !POINT_RULES[entry.key]) return;
  var count = entry.count || 1;
  var businessId = entry.business_id ? String(entry.business_id) : '';
  _auditEvents.push({
    user: normalizeName(entry.user) || 'Unknown',
    key: entry.key,
    label: POINT_RULES[entry.key].label,
    count: count,
    points: count * POINT_RULES[entry.key].points,
    detail: entry.detail || '',
    business_id: businessId,
    business_name: businessId && _businessNameMap[businessId] ? _businessNameMap[businessId] : '',
    source: entry.source || 'activity',
    created_at: entry.created_at || new Date().toISOString()
  });
}

function mergeRowInto(target, source) {
  if (!target || !source) return target;
  CATEGORY_ORDER.forEach(function(key){
    target.points[key] += source.points[key] || 0;
    target.counts[key] += source.counts[key] || 0;
  });
  target.total += source.total || 0;
  return target;
}

function matchMemberName(fullName, shortName) {
  var user = normalizeName(fullName).toLowerCase();
  var short = normalizeName(shortName).toLowerCase();
  if (!user || !short) return false;
  return user === short || user.indexOf(short + ' ') === 0;
}

function makeDateRange() {
  var start = document.getElementById('start-date').value;
  var end = document.getElementById('end-date').value;
  if (!start || !end) return null;
  if (start > end) return null;
  var startIso = new Date(start + 'T00:00:00').toISOString();
  var endDate = new Date(end + 'T00:00:00');
  endDate.setDate(endDate.getDate() + 1);
  return { start:start, end:end, startIso:startIso, endIso:endDate.toISOString() };
}

async function doLogin() {
  var email = normalizeName(document.getElementById('email').value);
  var password = document.getElementById('password').value || '';
  var status = document.getElementById('login-status');
  if (!email || !password) {
    status.textContent = 'Enter your email and password.';
