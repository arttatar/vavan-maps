<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Desert Strike Leader Board</title>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.js"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box}
:root{
  --bg:#130b07;
  --bg2:#23120b;
  --panel:#1c130f;
  --panel2:#271a14;
  --line:rgba(255,255,255,.08);
  --text:#fff7ef;
  --muted:#c7b29f;
  --accent:#ff8a1c;
  --accent2:#ffd166;
  --danger:#ff5b47;
  --sand:#f1d2a9;
  --shadow:0 20px 60px rgba(0,0,0,.32);
}
html,body{margin:0;padding:0;min-height:100%;font-family:'Inter',sans-serif;background:var(--bg);color:var(--text)}
body{
  background:
    radial-gradient(circle at top left, rgba(255,138,28,.25), transparent 28%),
    radial-gradient(circle at 85% 10%, rgba(255,209,102,.12), transparent 22%),
    radial-gradient(circle at bottom center, rgba(255,91,71,.10), transparent 26%),
    linear-gradient(180deg,#100906 0%,#1b100b 45%,#100906 100%);
}
.hidden{display:none !important}
.login{
  min-height:100vh;
  display:flex;
  align-items:center;
  justify-content:center;
  padding:24px;
}
.login-card,.panel{
  background:linear-gradient(180deg, rgba(255,255,255,.05), rgba(255,255,255,.025));
  border:1px solid var(--line);
  box-shadow:var(--shadow);
  border-radius:28px;
}
.login-card{
  width:100%;
  max-width:430px;
  padding:28px;
}
.eyebrow{
  font-size:11px;
  text-transform:uppercase;
  letter-spacing:.18em;
  color:var(--accent2);
  font-weight:800;
}
.login-card h1,.brand h1{
  margin:10px 0 8px 0;
  font-family:'Syne',sans-serif;
  line-height:.96;
}
.login-card h1{font-size:34px}
.login-card p{margin:0 0 18px 0;color:var(--muted);line-height:1.6;font-size:14px}
.field{margin-bottom:12px}
.field label{display:block;margin-bottom:6px;font-size:12px;font-weight:700;color:var(--sand)}
.field input,.date-input{
  width:100%;
  padding:12px 14px;
  border-radius:14px;
  border:1px solid rgba(255,255,255,.12);
  background:rgba(255,255,255,.06);
  color:var(--text);
  font:inherit;
  outline:none;
}
.field input:focus,.date-input:focus{border-color:var(--accent)}
.btn{
  border:none;
  border-radius:14px;
  padding:13px 16px;
  background:linear-gradient(135deg, var(--accent), #ffb44c);
  color:#2b1405;
  font:inherit;
  font-weight:800;
  cursor:pointer;
}
.btn:disabled{opacity:.6;cursor:not-allowed}
.btn-full{width:100%}
.status{min-height:18px;margin-top:10px;font-size:12px;color:var(--danger)}
.shell{max-width:1380px;margin:0 auto;padding:28px 20px 40px}
.season-strip{
  display:grid;
  grid-template-columns:1.2fr repeat(3,minmax(0,1fr));
  gap:12px;
  margin-bottom:18px;
}
.season-card{
  padding:16px 18px;
  border-radius:22px;
  border:1px solid rgba(255,255,255,.08);
  background:linear-gradient(180deg, rgba(255,255,255,.04), rgba(255,255,255,.02));
  box-shadow:var(--shadow);
}
.season-card.main{
  background:
    radial-gradient(circle at right top, rgba(255,209,102,.18), transparent 34%),
    linear-gradient(135deg, rgba(255,138,28,.14), rgba(255,91,71,.08));
}
.season-kicker{
  color:var(--accent2);
  text-transform:uppercase;
  letter-spacing:.14em;
  font-size:10px;
  font-weight:900;
}
.season-title{
  margin-top:8px;
  font-size:22px;
  font-weight:900;
  color:var(--text);
}
.season-copy{
  margin-top:6px;
  color:var(--muted);
  font-size:12px;
  line-height:1.55;
}
.season-metric-label{
  color:var(--muted);
  text-transform:uppercase;
  letter-spacing:.12em;
  font-size:10px;
  font-weight:800;
}
.season-metric-value{
  margin-top:8px;
  color:var(--text);
  font-size:30px;
  line-height:1;
  font-weight:900;
}
.season-metric-sub{
  margin-top:6px;
  color:var(--muted);
  font-size:12px;
}
.topbar{
  display:flex;
  justify-content:space-between;
  gap:18px;
  align-items:flex-start;
  margin-bottom:20px;
}
.brand{display:flex;flex-direction:column;gap:10px}
.brand h1{font-size:46px}
.subhead{margin:0;max-width:820px;color:var(--muted);font-size:14px;line-height:1.65}
.subhead strong{color:var(--text)}
.banner{
  display:inline-flex;
  align-items:center;
  gap:10px;
  padding:10px 14px;
  width:max-content;
  border-radius:999px;
  border:1px solid var(--line);
  background:linear-gradient(135deg, rgba(255,138,28,.18), rgba(255,209,102,.10));
  font-size:12px;
  font-weight:800;
}
.banner-dot{
  width:10px;height:10px;border-radius:50%;
  background:linear-gradient(135deg, var(--accent), #ffdf8b);
  box-shadow:0 0 20px rgba(255,138,28,.7);
}
.meta{
  display:flex;
  flex-wrap:wrap;
  justify-content:flex-end;
  gap:10px;
}
.pill{
  display:inline-flex;
  align-items:center;
  gap:8px;
  padding:10px 14px;
  border-radius:999px;
  border:1px solid var(--line);
  background:rgba(255,255,255,.04);
  color:var(--muted);
  font-size:12px;
}
.pill strong{color:var(--text)}
.grid{
  display:grid;
  grid-template-columns:1.1fr .9fr;
  gap:18px;
}
.panel{padding:20px}
.metrics{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:14px;
}
.metric{
  padding:16px;
  border-radius:20px;
  border:1px solid rgba(255,255,255,.06);
  background:rgba(255,255,255,.03);
}
.metric .label{
  font-size:11px;
  text-transform:uppercase;
  letter-spacing:.12em;
  color:var(--muted);
  font-weight:800;
}
.metric .value{
  margin-top:10px;
  font-size:34px;
  line-height:1;
  font-weight:800;
  color:var(--text);
}
.metric .sub{
  margin-top:6px;
  color:var(--muted);
  font-size:12px;
}
.section-head{
  display:flex;
  justify-content:space-between;
  gap:12px;
  align-items:flex-start;
  margin-bottom:16px;
}
.section-head h2{
  margin:0;
  font-size:20px;
  color:var(--text);
}
.section-head p{
  margin:4px 0 0 0;
  font-size:12px;
  color:var(--muted);
  max-width:700px;
  line-height:1.5;
}
.controls{
  display:flex;
  gap:10px;
  flex-wrap:wrap;
  align-items:flex-end;
}
.view-switch{
  display:inline-flex;
  gap:8px;
  margin-top:12px;
  flex-wrap:wrap;
}
.view-btn{
  border:1px solid rgba(255,255,255,.08);
  background:rgba(255,255,255,.04);
  color:var(--sand);
  border-radius:999px;
  padding:8px 14px;
  font:inherit;
  font-size:12px;
  font-weight:800;
  cursor:pointer;
}
.view-btn.active{
  background:linear-gradient(135deg, var(--accent), #ffb44c);
  color:#2b1405;
  border-color:transparent;
}
.control{
  min-width:150px;
}
.control label{
  display:block;
  margin-bottom:6px;
  color:var(--muted);
  font-size:11px;
  text-transform:uppercase;
  letter-spacing:.12em;
  font-weight:800;
}
.date-input{color-scheme:dark}
.leader-list{
  display:flex;
  flex-direction:column;
  gap:14px;
}
.leader-row{
  display:grid;
  grid-template-columns:auto 1fr auto;
  gap:14px;
  align-items:flex-start;
  padding:16px;
  border-radius:24px;
  border:1px solid rgba(255,255,255,.06);
  background:linear-gradient(180deg, rgba(255,255,255,.035), rgba(255,255,255,.02));
  position:relative;
  overflow:hidden;
}
.leader-row::after{
  content:"";
  position:absolute;
  inset:auto -20% 0 auto;
  width:180px;
  height:180px;
  border-radius:50%;
  background:radial-gradient(circle, rgba(255,209,102,.10), transparent 70%);
  pointer-events:none;
}
.leader-row.top-1{
  border-color:rgba(255,209,102,.35);
  background:
    radial-gradient(circle at right top, rgba(255,209,102,.15), transparent 28%),
    linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.025));
  box-shadow:0 18px 40px rgba(255,209,102,.08);
}
.leader-row.top-2{
  border-color:rgba(209,224,255,.18);
}
.leader-row.top-3{
  border-color:rgba(255,164,108,.18);
}
.rank{
  width:58px;
  height:58px;
  border-radius:18px;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:24px;
  font-weight:900;
  color:#fff;
  background:linear-gradient(135deg, rgba(255,138,28,.28), rgba(255,91,71,.14));
}
.leader-row.top-1 .rank{
  background:linear-gradient(135deg, #ffd166, #ff9f1c);
  color:#2e1700;
}
.leader-row.top-2 .rank{
  background:linear-gradient(135deg, #d7e4f9, #98a8c7);
  color:#1f2430;
}
.leader-row.top-3 .rank{
  background:linear-gradient(135deg, #ffc68f, #c9783d);
  color:#2f1704;
}
.rep-name{
  font-size:26px;
  line-height:1.05;
  font-weight:800;
  color:var(--text);
}
.rep-sub{
  margin-top:4px;
  color:var(--muted);
  font-size:12px;
}
.rep-topline{
  display:flex;
  gap:10px;
  flex-wrap:wrap;
  align-items:center;
}
.rank-title{
  display:inline-flex;
  align-items:center;
  gap:6px;
  padding:5px 10px;
  border-radius:999px;
  background:rgba(255,255,255,.05);
  border:1px solid rgba(255,255,255,.08);
  color:var(--sand);
  font-size:10px;
  font-weight:900;
  text-transform:uppercase;
  letter-spacing:.12em;
}
.leader-row.top-1 .rank-title{
  background:rgba(255,209,102,.12);
  border-color:rgba(255,209,102,.22);
  color:#ffe8ae;
}
.progress-track{
  margin-top:12px;
  height:10px;
  width:100%;
  border-radius:999px;
  background:rgba(255,255,255,.06);
  overflow:hidden;
  border:1px solid rgba(255,255,255,.04);
}
.progress-fill{
  height:100%;
  border-radius:999px;
  background:linear-gradient(90deg, var(--accent), var(--accent2));
  box-shadow:0 0 20px rgba(255,138,28,.25);
}
.progress-copy{
  margin-top:6px;
  color:var(--muted);
  font-size:11px;
}
.total-box{
  min-width:120px;
  text-align:center;
  padding:12px 16px;
  border-radius:20px;
  border:1px solid rgba(255,255,255,.08);
  background:rgba(255,255,255,.04);
}
.leader-row.top-1 .total-box{
  background:linear-gradient(180deg, rgba(255,209,102,.12), rgba(255,255,255,.04));
  border-color:rgba(255,209,102,.24);
}
.total-label{
  font-size:11px;
  letter-spacing:.12em;
  text-transform:uppercase;
  color:var(--muted);
  font-weight:800;
}
.total-value{
  margin-top:6px;
  font-size:40px;
  line-height:1;
  font-weight:900;
  color:var(--accent2);
}
.stat-grid{
  grid-column:2 / 4;
  display:grid;
  grid-template-columns:repeat(5,minmax(0,1fr));
  gap:10px;
}
.stat-chip{
  padding:12px 10px;
  border-radius:18px;
  background:rgba(255,255,255,.03);
  border:1px solid rgba(255,255,255,.06);
  min-height:82px;
  transition:transform .18s ease,border-color .18s ease,box-shadow .18s ease,background .18s ease;
}
.stat-chip.hot{
  background:linear-gradient(180deg, rgba(255,138,28,.11), rgba(255,255,255,.03));
  border-color:rgba(255,138,28,.22);
}
.stat-chip.clickable{
  cursor:pointer;
}
.stat-chip.clickable:hover{
  transform:translateY(-2px);
  border-color:rgba(255,209,102,.24);
  box-shadow:0 12px 28px rgba(0,0,0,.16);
}
.stat-chip.active-filter{
  background:linear-gradient(180deg, rgba(255,209,102,.14), rgba(255,138,28,.07));
  border-color:rgba(255,209,102,.34);
  box-shadow:0 0 0 1px rgba(255,209,102,.12) inset;
}
.stat-label{
  font-size:10px;
  text-transform:uppercase;
  letter-spacing:.12em;
  color:var(--muted);
  font-weight:800;
}
.stat-value{
  margin-top:10px;
  font-size:28px;
  line-height:1;
  font-weight:800;
  color:var(--text);
}
.stat-points{
  margin-top:8px;
  color:var(--accent2);
  font-size:11px;
  font-weight:700;
}
.section-mode{
  display:inline-flex;
  align-items:center;
  gap:8px;
  margin-top:10px;
  padding:6px 10px;
  border-radius:999px;
  border:1px solid rgba(255,255,255,.08);
  background:rgba(255,255,255,.04);
  color:var(--sand);
  font-size:11px;
  font-weight:800;
}
.rules{
  display:grid;
  grid-template-columns:repeat(2,minmax(0,1fr));
  gap:12px;
}
.rule{
  padding:14px;
  border-radius:18px;
  background:rgba(255,255,255,.03);
  border:1px solid rgba(255,255,255,.06);
}
.rule-top{
  display:flex;
  justify-content:space-between;
  gap:12px;
  align-items:baseline;
}
.rule-title{
  font-size:14px;
  font-weight:800;
  color:var(--text);
}
.rule-points{
  font-size:18px;
  font-weight:900;
  color:var(--accent2);
}
.rule-note{
  margin-top:6px;
  color:var(--muted);
  font-size:12px;
  line-height:1.5;
}
.note-box{
  margin-top:14px;
  padding:14px;
  border-radius:18px;
  background:rgba(255,138,28,.07);
  border:1px solid rgba(255,138,28,.15);
  color:var(--sand);
  font-size:12px;
  line-height:1.6;
}
.audit-panel{
  margin-top:18px;
}
.audit-controls{
  display:flex;
  gap:8px;
  flex-wrap:wrap;
  align-items:center;
}
.audit-filter-chip{
  display:inline-flex;
  align-items:center;
  gap:6px;
  border:1px solid rgba(255,255,255,.08);
  background:rgba(255,255,255,.04);
  color:var(--sand);
  border-radius:999px;
  padding:8px 12px;
  font:inherit;
  font-size:11px;
  font-weight:800;
  cursor:pointer;
}
.audit-filter-chip.active{
  background:linear-gradient(135deg, var(--accent), #ffb44c);
  color:#2b1405;
  border-color:transparent;
}
.audit-list{
  display:flex;
  flex-direction:column;
  gap:10px;
}
.audit-row{
  display:grid;
  grid-template-columns:auto 1fr auto;
  gap:12px;
  align-items:start;
  padding:14px;
  border-radius:18px;
  border:1px solid rgba(255,255,255,.06);
  background:rgba(255,255,255,.03);
}
.audit-points{
  min-width:72px;
  padding:10px 8px;
  text-align:center;
  border-radius:14px;
  background:linear-gradient(135deg, rgba(255,138,28,.22), rgba(255,209,102,.12));
  color:var(--accent2);
  font-size:22px;
  font-weight:900;
  line-height:1;
}
.audit-points span{
  display:block;
  margin-top:4px;
  font-size:10px;
  letter-spacing:.12em;
  text-transform:uppercase;
  color:var(--sand);
}
.audit-title{
  font-size:14px;
  font-weight:800;
  color:var(--text);
}
.audit-meta{
  margin-top:5px;
  color:var(--muted);
  font-size:12px;
  line-height:1.5;
}
.audit-tag{
  display:inline-flex;
  align-items:center;
  gap:6px;
  padding:6px 10px;
  border-radius:999px;
  border:1px solid rgba(255,255,255,.08);
  background:rgba(255,255,255,.04);
  color:var(--sand);
  font-size:10px;
  font-weight:800;
  text-transform:uppercase;
  letter-spacing:.12em;
}
.empty{
  padding:30px 16px;
  text-align:center;
  color:var(--muted);
  font-size:14px;
}
@media (max-width: 1150px){
  .season-strip{grid-template-columns:1fr 1fr}
  .grid{grid-template-columns:1fr}
  .metrics{grid-template-columns:repeat(2,1fr)}
}
@media (max-width: 780px){
  .shell{padding:20px 14px 28px}
  .season-strip{grid-template-columns:1fr}
  .topbar{flex-direction:column}
  .brand h1{font-size:36px}
  .metrics{grid-template-columns:1fr}
  .rules{grid-template-columns:1fr}
  .leader-row{grid-template-columns:auto 1fr}
  .total-box{grid-column:2}
  .stat-grid{grid-column:1 / -1;grid-template-columns:repeat(2,minmax(0,1fr))}
}
</style>
</head>
<body>
<div id="login-view" class="login hidden">
  <div class="login-card">
    <div class="eyebrow">InterState Oil Blitz</div>
    <h1>Desert Strike<br>Leader Board</h1>
    <p>Sign in with an InterState Oil client user to open the blitz board. This page reads live sales activity from Supabase and turns it into points.</p>
    <div class="field">
      <label for="email">Email</label>
      <input id="email" type="email" autocomplete="email">
    </div>
    <div class="field">
      <label for="password">Password</label>
      <input id="password" type="password" autocomplete="current-password">
    </div>
    <button class="btn btn-full" id="login-btn">Open Leader Board</button>
    <div class="status" id="login-status"></div>
  </div>
</div>

<div id="app-view" class="hidden">
  <div class="shell">
    <div class="season-strip">
      <div class="season-card main">
        <div class="season-kicker">Live Season</div>
        <div class="season-title">Desert Strike: Market Blitz</div>
        <div class="season-copy">Every rep is chasing points by visiting accounts, uncovering supplier intel, collecting credit app progress, and stacking field actions faster than the rest of the team.</div>
      </div>
      <div class="season-card">
        <div class="season-metric-label">Game Mode</div>
        <div class="season-metric-value">Field Rush</div>
        <div class="season-metric-sub">Live points from real activity in Supabase.</div>
      </div>
      <div class="season-card">
        <div class="season-metric-label">Win Condition</div>
        <div class="season-metric-value">Top Total</div>
        <div class="season-metric-sub">Highest blitz points owns the board.</div>
      </div>
      <div class="season-card">
        <div class="season-metric-label">Power Move</div>
        <div class="season-metric-value">10 Pts</div>
        <div class="season-metric-sub">Competitor invoice or collected credit app.</div>
      </div>
    </div>

    <div class="topbar">
      <div class="brand">
        <div class="eyebrow">InterState Oil Market Blitz</div>
        <h1>Desert Strike Leader Board</h1>
      </div>
      <div class="meta">
        <div class="pill">Client <strong id="client-name">Loading...</strong></div>
        <div class="pill">Viewer <strong id="viewer-name">Loading...</strong></div>
        <div class="pill">Updated <strong id="updated-at">-</strong></div>
      </div>
    </div>

    <div class="panel" style="margin-bottom:18px;">
      <div class="metrics" id="summary-grid"></div>
    </div>

    <div class="grid">
      <div class="panel">
        <div class="section-head">
          <div>
            <h2 id="board-title">Rep Standings</h2>
            <div class="view-switch">
              <button class="view-btn active" id="view-team-btn" onclick="setBoardView('team')">Team Leader Board</button>
              <button class="view-btn" id="view-user-btn" onclick="setBoardView('user')">User Leader Board</button>
              <button class="view-btn" id="view-lone-btn" onclick="setBoardView('lone')">Lone Wolf</button>
            </div>
          </div>
          <div class="controls">
            <div class="control">
              <label for="start-date">Start</label>
              <input class="date-input" id="start-date" type="date">
            </div>
            <div class="control">
              <label for="end-date">End</label>
              <input class="date-input" id="end-date" type="date">
            </div>
            <button class="btn" id="reload-btn" onclick="loadBoard()">Reload</button>
          </div>
        </div>
        <div id="leader-list" class="leader-list"></div>
      </div>

      <div class="panel">
        <div class="section-head">
          <div>
            <h2>Point Rules</h2>
            <p>These are the current blitz weights driving the leaderboard.</p>
          </div>
        </div>
        <div id="rules-grid" class="rules"></div>
        <div class="note-box">
